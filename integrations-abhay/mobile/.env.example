# =============================================================================
# CareMap Mobile — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Expo uses EXPO_PUBLIC_ prefix for client-accessible variables.
# =============================================================================

# Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous key (safe for client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Edge Functions base URL (optional, defaults to {SUPABASE_URL}/functions/v1)
# Override this for local development with supabase functions serve
EXPO_PUBLIC_SUPABASE_FUNCTIONS_BASE_URL=http://localhost:54321/functions/v1
