# =============================================================================
# CareMap Integrations — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Your Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key (safe for client-side, has RLS restrictions)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (DEV ONLY — bypasses RLS, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Google Maps / Places API
# -----------------------------------------------------------------------------
# API key with Places API (New) enabled
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Places API base URL (New Places API)
GOOGLE_PLACES_API_BASE=https://places.googleapis.com

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Set to "true" to use mock data instead of real API calls
# Recommended for local dev without API keys
MOCK_MODE=true

# Default coordinates (Pittsburgh, PA — for testing)
DEFAULT_LAT=40.4406
DEFAULT_LNG=-79.9959

# -----------------------------------------------------------------------------
# Development Auth Bypass (DEV ONLY)
# -----------------------------------------------------------------------------
# Set to "true" to skip JWT verification in Edge Functions.
# WARNING: Only use for local demos. Never enable in production!
DEV_BYPASS_AUTH=false
