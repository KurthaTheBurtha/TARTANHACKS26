# CareMap — Canonical environment variable contract (do not commit real keys)
# Copy to .env in the appropriate app directory and fill in values.
# See backend/.env.example, bill-parser/.env.example, integrations-abhay/.env.example for app-specific templates.

# ---------- API Keys (optional; missing keys enable mock/stub mode) ----------
OPENAI_API_KEY=              # Backend: RAG, embeddings, doc analysis
GEMINI_API_KEY=               # Bill-parser: PDF bill parsing (Google AI Studio)
ANTHROPIC_API_KEY=            # Bill-parser: optional Claude-based parsing

# ---------- Supabase (backend + integrations + mobile) ----------
SUPABASE_URL=                 # Project URL (e.g. https://xxx.supabase.co)
SUPABASE_ANON_KEY=            # Public anon key (frontend / mobile safe)
SUPABASE_SERVICE_ROLE_KEY=    # Backend & Edge only — never expose to client
SUPABASE_JWT_SECRET=          # Backend: JWT verification (Project Settings > JWT)

# ---------- Google (integrations Edge Functions) ----------
GOOGLE_MAPS_API_KEY=          # Provider search (Places API); optional if MOCK_MODE=true

# ---------- Ports & URLs (local dev) ----------
BACKEND_PORT=8000
# Next.js uses PORT (default 3000) for bill-parser
# NEXT_PUBLIC_CAREMAP_BACKEND_URL=http://localhost:8000  # Bill-parser → backend
# BILL_PARSER_URL=http://localhost:3000                   # Backend CareMap → bill-parser
# FUNCTIONS_BASE_URL=http://localhost:54321/functions/v1 # Backend CareMap → Edge Functions

# ---------- Optional / demo ----------
# DEV_BYPASS_AUTH=false       # Integrations Edge: set true only for local demos
# MOCK_MODE=true              # Integrations Edge: mock provider data
# EXPO_PUBLIC_*               # Mobile: see integrations-abhay/mobile/.env.example
