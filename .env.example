# CareMap — Copy to .env and fill in values. All apps read from repo root .env
# Never commit .env

# ---------- API keys (optional; mock mode when missing) ----------
OPENAI_API_KEY=                    # Backend: RAG, embeddings, guidance
GEMINI_API_KEY=                    # Backend (when LLM_PROVIDER=gemini); Frontend: bill parsing
LLM_PROVIDER=openai                # Backend: openai | gemini

# ---------- Supabase (optional; mock when missing) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# ---------- Ports & URLs (REQUIRED for frontend ↔ backend connection) ----------
BACKEND_PORT=8000
PORT=3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_CAREMAP_BACKEND_URL=http://localhost:8000
BILL_PARSER_URL=http://localhost:3000

# Frontend calls backend at NEXT_PUBLIC_*_URL
# Backend calls frontend's /api/parse-bill at BILL_PARSER_URL for bill parsing

# ---------- Optional ----------
FUNCTIONS_BASE_URL=                # CareMap provider search (Supabase Edge)
DEMO_MODE=false                   # true = deterministic fixture, no external calls
CAREMAP_INGEST_REQUIRE_AUTH=false # true = require JWT for CareMap ingest
TEST_BYPASS_AUTH=true             # true = chat works without login (X-Test-User: demo_user)
